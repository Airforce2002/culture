---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Discover authentic Chinese culture - food, history, fashion, poetry, martial arts, and Daoist philosophy">
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-red-900 via-red-800 to-stone-900 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 80 80\"><path fill=\"%23fff\" d=\"M40 0L50 30L80 40L50 50L40 80L30 50L0 40L30 30Z\"/></svg>'); background-size: 60px;"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-6xl font-bold mb-6 leading-tight">
          Discover the Real <span class="text-amber-400">China</span>
        </h1>
        <p class="text-xl md:text-2xl text-stone-200 mb-8 leading-relaxed">
          Beyond the stereotypes lies 5,000 years of breathtaking culture. Explore food, history, fashion, poetry, martial arts, and philosophy—all explained with depth and authenticity.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#explore" class="px-8 py-4 bg-amber-500 text-stone-900 font-semibold rounded-lg hover:bg-amber-400 transition-colors">
            Start Exploring
          </a>
          <a href="/newsletter" class="px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white hover:text-red-900 transition-colors">
            Join Newsletter
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-white border-b border-stone-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-red-700">5000+</div>
          <div class="text-stone-500 text-sm">Years of History</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-red-700">8</div>
          <div class="text-stone-500 text-sm">Major Cuisines</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-red-700">30K+</div>
          <div class="text-stone-500 text-sm">Poems Preserved</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-red-700">100+</div>
          <div class="text-stone-500 text-sm">Martial Arts Styles</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Six Pillars Section -->
  <section id="explore" class="py-20 bg-stone-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-stone-900 mb-4">Six Pillars of Chinese Culture</h2>
        <p class="text-lg text-stone-600 max-w-2xl mx-auto">Every aspect of Chinese civilization is interconnected. Explore how food shapes philosophy, how poetry influences fashion, and how ancient wisdom applies today.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Food -->
        <a href="/food" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center text-6xl">
            🍜
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-2 group-hover:text-red-700 transition-colors">Chinese Cuisine</h3>
            <p class="text-stone-600 text-sm mb-4">From Sichuan's fire to Cantonese subtlety. Explore the eight great cuisines, street food culture, tea ceremonies, and medicinal cooking.</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-orange-100 text-orange-700 text-xs rounded-full">8 Cuisines</span>
              <span class="px-2 py-1 bg-orange-100 text-orange-700 text-xs rounded-full">Tea Culture</span>
              <span class="px-2 py-1 bg-orange-100 text-orange-700 text-xs rounded-full">Street Food</span>
            </div>
          </div>
        </a>

        <!-- History -->
        <a href="/history" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-amber-600 to-orange-700 flex items-center justify-center text-6xl">
            📜
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-2 group-hover:text-red-700 transition-colors">Chinese History</h3>
            <p class="text-stone-600 text-sm mb-4">Dynasties rise and fall. Emperors dream and scheme. Discover the fascinating stories behind 5,000 years of civilization.</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs rounded-full">Dynasties</span>
              <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs rounded-full">Emperors</span>
              <span class="px-2 py-1 bg-amber-100 text-amber-700 text-xs rounded-full">Inventions</span>
            </div>
          </div>
        </a>

        <!-- Clothing -->
        <a href="/clothing" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-pink-500 to-rose-600 flex items-center justify-center text-6xl">
            👘
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-2 group-hover:text-red-700 transition-colors">Traditional Clothing</h3>
            <p class="text-stone-600 text-sm mb-4">The elegance of hanfu, the allure of cheongsam, the craftsmanship of silk. Explore China's textile heritage.</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-pink-100 text-pink-700 text-xs rounded-full">Hanfu</span>
              <span class="px-2 py-1 bg-pink-100 text-pink-700 text-xs rounded-full">Cheongsam</span>
              <span class="px-2 py-1 bg-pink-100 text-pink-700 text-xs rounded-full">Silk</span>
            </div>
          </div>
        </a>

        <!-- Poetry -->
        <a href="/poetry" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-6xl">
            ✒️
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-2 group-hover:text-red-700 transition-colors">Poetry & Calligraphy</h3>
            <p class="text-stone-600 text-sm mb-4">Where words become art. Tang poetry, Song lyrics, and the meditative practice of Chinese calligraphy.</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded-full">Tang Poetry</span>
              <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded-full">Calligraphy</span>
              <span class="px-2 py-1 bg-blue-100 text-blue-700 text-xs rounded-full">Poets</span>
            </div>
          </div>
        </a>

        <!-- Martial Arts -->
        <a href="/martial" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-green-600 to-emerald-700 flex items-center justify-center text-6xl">
            🥋
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-2 group-hover:text-red-700 transition-colors">Martial Arts & TCM</h3>
            <p class="text-stone-600 text-sm mb-4">From Shaolin's thundering fists to Tai Chi's flowing grace. Plus the wisdom of Traditional Chinese Medicine.</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded-full">Kung Fu</span>
              <span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded-full">Tai Chi</span>
              <span class="px-2 py-1 bg-green-100 text-green-700 text-xs rounded-full">TCM</span>
            </div>
          </div>
        </a>

        <!-- Daoism -->
        <a href="/daoism" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-gradient-to-br from-teal-600 to-cyan-700 flex items-center justify-center text-6xl">
            ☯️
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-stone-900 mb-2 group-hover:text-red-700 transition-colors">Daoist Philosophy</h3>
            <p class="text-stone-600 text-sm mb-4">The wisdom of Laozi, the poetry of Zhuangzi, the eternal dance of yin and yang. Discover China's spiritual heart.</p>
            <div class="flex flex-wrap gap-2">
              <span class="px-2 py-1 bg-teal-100 text-teal-700 text-xs rounded-full">Tao Te Ching</span>
              <span class="px-2 py-1 bg-teal-100 text-teal-700 text-xs rounded-full">Zhuangzi</span>
              <span class="px-2 py-1 bg-teal-100 text-teal-700 text-xs rounded-full">Yin & Yang</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="py-20 bg-red-900 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Get Weekly Cultural Insights</h2>
      <p class="text-stone-300 mb-8">Join thousands of curious minds exploring Chinese culture. Every week: one deep dive, curated stories, and exclusive content.</p>
      <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
        <input type="email" placeholder="your@email.com" class="flex-1 px-4 py-3 rounded-lg text-stone-900" />
        <button type="submit" class="px-6 py-3 bg-amber-500 text-stone-900 font-semibold rounded-lg hover:bg-amber-400 transition-colors">
          Subscribe
        </button>
      </form>
    </div>
  </section>
</Layout>
